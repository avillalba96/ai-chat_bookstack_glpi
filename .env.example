# =============================================================================
# WIKI-AGENTAI — variables de entorno
# =============================================================================
# Inicio rápido: copiá este archivo a .env y completá el bloque MÍNIMO abajo.
# El resto puede quedar como está: el proyecto ya elige modelo, visión automática
# y recortes de contexto pensados para cuotas típicas de APIs.
#
# Nunca subas .env a Git (está en .gitignore).
# El LLM usa una API compatible con OpenAI (POST …/chat/completions): Groq, OpenAI,
# Ollama en http://127.0.0.1:11434/v1, LiteLLM, proxies, etc. Las variables GROQ_*
# siguen funcionando como respaldo si no definís LLM_*.
# =============================================================================

# -----------------------------------------------------------------------------
# MÍNIMO — solo esto necesitás para empezar (4 valores + URL de tu wiki)
# -----------------------------------------------------------------------------
BOOKSTACK_BASE_URL="https://tu-bookstack.ejemplo.edu.ar"
BOOKSTACK_TOKEN_ID=""
BOOKSTACK_TOKEN_SECRET=""
# Clave del proveedor (o vacía con Ollama en localhost; ver LLM_BASE_URL abajo).
LLM_API_KEY=""
# Compatibilidad: si solo tenés esto, también sirve.
GROQ_API_KEY=""

# -----------------------------------------------------------------------------
# Por defecto del proyecto (no hace falta tocarlo el primer día)
# -----------------------------------------------------------------------------
# Base del endpoint OpenAI-compatible (vacío = https://api.groq.com/openai/v1 si hay clave).
# Ollama local: LLM_BASE_URL="http://127.0.0.1:11434/v1" y LLM_API_KEY=""
# OPENAI_COMPAT_BASE_URL es alias opcional de LLM_BASE_URL (misma prioridad que en código: LLM_ primero).
LLM_BASE_URL=""
OPENAI_COMPAT_BASE_URL=""
BOOKSTACK_HTTP_TIMEOUT_S="25"
# Modelo de texto. La visión usa LLM_VISION_MODEL solo si hay capturas de la wiki.
LLM_MODEL="llama-3.1-8b-instant"
LLM_MAX_TOKENS="420"
LLM_TEMPERATURE="0.1"
LLM_HTTP_TIMEOUT_S="45"
LLM_VISION_MODEL="meta-llama/llama-4-scout-17b-16e-instruct"
# Respaldo GROQ_* (mismos valores por defecto que LLM_*)
GROQ_MODEL="llama-3.1-8b-instant"
GROQ_MAX_TOKENS="420"
GROQ_TEMPERATURE="0.1"
GROQ_HTTP_TIMEOUT_S="45"
GROQ_VISION_MODEL="meta-llama/llama-4-scout-17b-16e-instruct"

# Calidad general: economy | balanced | thorough (afecta cuánta wiki se trae por consulta)
WIKI_QUALITY_MODE="balanced"

# Visión automática: true = si hay imágenes en las fuentes, usa Scout; si no, solo texto.
WIKI_VISION_ENABLED="true"
WIKI_VISION_MAX_IMAGES="3"
WIKI_VISION_MAX_BYTES="4000000"

# Tono e identidad del asistente (archivos Markdown en el repo)
WIKI_PERSONA_FILE="persona/PERSONA.md"
WIKI_CONSTRAINTS_FILE="persona/CONSTRAINTS.md"
# Opcional: una línea para el tono del día (vacío = sin extra)
WIKI_AI_MOOD=""

# Recorte de búsqueda y contexto (tokens / tamaño del prompt al LLM)
WIKI_TOP_K="3"
WIKI_KEYWORD_MAX="8"
# Búsqueda BookStack: variantes automáticas (sin listas temáticas en código). Opcional por institución:
# WIKI_SEARCH_MAX_VARIANTS="16"
# WIKI_SEARCH_PREFIX_MAX_CHARS="72"
# WIKI_SEARCH_STRIP_PREFIX_REGEX=""   # si querés reemplazar otro prefijo fijo (regex, una sustitución)
# WIKI_SEARCH_VARIANTS_FILE="config/wiki_search_frases.txt"   # una frase por línea (# comentario)
# WIKI_SEARCH_STOPWORDS_FILE="config/wiki_search_stopwords.txt"  # palabras a ignorar al armar n-gramas
# Orden al armar contexto para el LLM: updated_at (más reciente primero) o search (orden de la API)
# WIKI_BOOKSTACK_PAGE_SORT="updated_at"
# Subcadenas en la URL que relegan páginas viejas (p. ej. libros *-old): lista separada por comas
# WIKI_PAGE_URL_DEMOTE_SUBSTRINGS="-old,instructivos-old,servidores-old"
WIKI_PAGE_MAX_CHARS="1800"
WIKI_CONTEXT_MAX_CHARS="9000"
WIKI_RELEVANT_MAX_LINES="55"
WIKI_EVIDENCE_LINES_PAGE="5"
WIKI_EVIDENCE_LINES_PDF="3"
WIKI_EVIDENCE_LINES_TEXT="3"
WIKI_EVIDENCE_MAX_UNIQUE="10"

WIKI_ATTACH_PDF="true"
WIKI_PDF_MAX_PAGES="8"
WIKI_PDF_MAX_CHARS="2500"
WIKI_PDF_MAX_FILES="2"
WIKI_PDF_CONTEXT_BUDGET="4000"

WIKI_HTML_ASSETS="true"
WIKI_ASSETS_MAX_LINKS="22"
WIKI_ASSETS_MAX_IMAGES="12"
WIKI_ASSETS_CONTEXT_BUDGET="2200"

WIKI_GALLERY="true"
WIKI_GALLERY_MAX_IMAGES="8"

WIKI_ATTACH_TEXT="true"
WIKI_TEXT_ATTACH_MAX_FILES="2"
WIKI_TEXT_ATTACH_MAX_CHARS="3500"
WIKI_TEXT_CONTEXT_BUDGET="5000"

# Archivo .env alternativo (vacío = .env en la raíz del proyecto)
WIKI_DOTENV_PATH=""

# Opcional: número fijo para ?v= en CSS/JS (si no se define, cambia al reiniciar el servidor).
# WIKI_STATIC_ASSET_V="1"

# Interfaz web (wiki-web). Reiniciá el servidor tras cambiar host/puerto.
# 0.0.0.0 = accesible en la red local (poné detrás HAProxy + TLS en producción).
WIKI_WEB_HOST="0.0.0.0"
WIKI_WEB_PORT="8081"
# Miniaturas en el chat (no afecta tokens del LLM; solo HTML)
WIKI_WEB_GALLERY_MAX="16"
# Proxy hacia BookStack (PDF, imágenes, etc.): solo memoria, sin archivo en disco en el servidor
WIKI_PROXY_MAX_BYTES="40000000"
WIKI_PROXY_HTTP_TIMEOUT_S="120"

# Textos de la barra superior (interfaz web)
WIKI_UI_PRODUCT_NAME="Wiki AI Agent"
WIKI_UI_TAGLINE="Consultá tu wiki y tickets GLPI para resolver casos."

# Historial de conversación enviado al LLM (interfaz web; recorte para ahorrar tokens)
WIKI_CHAT_HISTORY_MAX_MESSAGES="12"
WIKI_CHAT_HISTORY_USER_MAX_CHARS="800"
WIKI_CHAT_HISTORY_ASSISTANT_MAX_CHARS="1400"

# -----------------------------------------------------------------------------
# GLPI (mesa de ayuda) — búsqueda opcional junto a la wiki
# -----------------------------------------------------------------------------
# En la interfaz podés elegir «Solo wiki», «Solo GLPI» o «Wiki + GLPI» (también WIKI_SEARCH_SOURCE por defecto).
WIKI_SEARCH_SOURCE="wiki"
WIKI_GLPI_ENABLED="false"
# URL del sitio (sin /front/...): la API se usa en https://…/apirest.php
GLPI_BASE_URL="https://glpi.tu-organizacion.example"
# Recomendado: «Clave de acceso remoto» (perfil de usuario en GLPI). No compartas ni subas el token a Git.
GLPI_USER_TOKEN=""
# Si tu GLPI exige «App-Token» (Configuración → General → API → cliente API), pegalo acá:
GLPI_APP_TOKEN=""
# Alternativa poco recomendada: LDAP/local con usuario y contraseña (usar solo si no podés usar user token)
GLPI_LOGIN=""
GLPI_PASSWORD=""
GLPI_HTTP_TIMEOUT_S="45"
# true = initSession con session_write (suele hacer falta para ver notas internas según tu perfil)
GLPI_API_SESSION_WRITE="true"
# Campos de búsqueda del motor GLPI (si falla la búsqueda en seguimientos, ajustá con GET …/listSearchOptions/ITILFollowup)
GLPI_TICKET_TITLE_SEARCH_FIELD="1"
GLPI_TICKET_CONTENT_SEARCH_FIELD="21"
GLPI_TICKET_ID_SEARCH_FIELD="2"
WIKI_GLPI_SEARCH_IN_FOLLOWUPS="true"
GLPI_ITILFOLLOWUP_CONTENT_FIELD="5"
GLPI_ITILFOLLOWUP_ITEMS_ID_KEY="7"
# Si vacío, no filtra por tipo de ítem del seguimiento; si tu GLPI lo necesita, probá GLPI_ITILFOLLOWUP_ITEMTYPE_KEY="2"
GLPI_ITILFOLLOWUP_ITEMTYPE_KEY=""
GLPI_ITILFOLLOWUP_ITEMTYPE_CONTAINS="Ticket"
# Pocos tickets + ranking por palabras clave reduce 413 y ruido en el prompt.
WIKI_GLPI_MAX_TICKETS="3"
WIKI_GLPI_CONTEXT_MAX_CHARS="28000"
WIKI_GLPI_TICKET_DESC_MAX_CHARS="8000"
WIKI_GLPI_MAX_FOLLOWUPS="40"
WIKI_GLPI_FOLLOWUP_MAX_CHARS="2500"
WIKI_GLPI_MAX_TICKET_USERS="40"
WIKI_GLPI_MAX_GROUP_LINKS="20"
WIKI_GLPI_MAX_SOLUTIONS="5"
WIKI_GLPI_MAX_TICKET_LINKS="15"
WIKI_GLPI_MAX_TASKS="20"
# Tamaño máximo del mensaje de usuario al LLM (incluye contexto wiki/GLPI pegado).
WIKI_LLM_USER_MESSAGE_MAX_CHARS="14000"
WIKI_GROQ_USER_MESSAGE_MAX_CHARS="14000"
# Con mucho contexto GLPI subí LLM_MAX_TOKENS (p. ej. 800–1200) para respuestas más largas.

# -----------------------------------------------------------------------------
# Avanzado — solo si ya entendés el impacto en tokens / CPU / cuota
# -----------------------------------------------------------------------------
# WIKI_VISION_ENABLED="false"
# WIKI_TOP_K="2"
# GROQ_MAX_TOKENS="320"
